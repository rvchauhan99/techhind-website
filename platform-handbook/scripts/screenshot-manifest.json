{
  "baseUrl": "https://demo.techhind.in",
  "viewport": { "width": 1920, "height": 1080 },
  "defaultWaitMs": 2000,
  "screenshots": [
    { "route": "/auth/login", "filename": "auth-login.png", "public": true, "waitSelector": "form", "fullPage": false },
    { "route": "/home", "filename": "dashboard-home.png", "module": "dashboard", "waitSelector": "main", "fullPage": false },
    { "route": "/inquiry", "filename": "inquiry-kanban.png", "module": "inquiry", "fullPage": false, "actions": [{ "type": "click", "selector": "button:has-text('Kanban'), [data-view='kanban']", "optional": true }] },
    { "route": "/inquiry/add", "filename": "inquiry-add-form.png", "module": "inquiry", "fullPage": false, "waitSelector": "form" },
    { "route": "/inquiry/{{inquiryId}}", "filename": "inquiry-detail.png", "module": "inquiry", "fullPage": false, "requiresId": "inquiryId" },
    { "route": "/marketing-leads", "filename": "marketing-leads-kanban.png", "module": "marketing-leads", "fullPage": false },
    { "route": "/marketing-leads/view?id={{marketingLeadId}}", "filename": "marketing-lead-detail.png", "module": "marketing-leads", "fullPage": false, "requiresId": "marketingLeadId" },
    { "route": "/quotation/add", "filename": "quotation-add-form.png", "module": "quotation", "fullPage": false, "waitSelector": "form" },
    { "route": "/quotation/{{quotationId}}", "filename": "quotation-pdf-preview.png", "module": "quotation", "fullPage": false, "requiresId": "quotationId", "actions": [{ "type": "wait", "ms": 4000 }] },
    { "route": "/quotation/manager-approval", "filename": "quotation-manager-approval.png", "module": "quotation", "fullPage": false, "actions": [{ "type": "click", "selector": "table tbody tr:first-child button, table tbody tr:first-child a", "optional": true }, { "type": "wait", "ms": 2000 }] },
    { "route": "/order/add", "filename": "order-add-form.png", "module": "orders", "fullPage": false },
    { "route": "/order/view?id={{pendingOrderId}}&tab=2", "filename": "order-payment-tab.png", "module": "orders", "fullPage": false, "requiresId": "pendingOrderId" },
    { "route": "/confirm-orders/view?id={{confirmOrderId}}", "filename": "confirm-order-pipeline.png", "module": "orders", "fullPage": false, "requiresId": "confirmOrderId" },
    { "route": "/confirm-orders/view?id={{confirmOrderId}}", "filename": "confirm-order-delivery.png", "module": "orders", "fullPage": false, "requiresId": "confirmOrderId", "actions": [{ "type": "click", "selector": "text=Delivery", "optional": true }, { "type": "wait", "ms": 2500 }] },
    { "route": "/confirm-orders/view?id={{confirmOrderId}}", "filename": "confirm-order-installation.png", "module": "orders", "fullPage": false, "requiresId": "confirmOrderId", "actions": [{ "type": "click", "selector": "text=Installation", "optional": true }, { "type": "wait", "ms": 2500 }] },
    { "route": "/confirm-orders", "filename": "confirm-order-drawer.png", "module": "orders", "fullPage": false, "actions": [{ "type": "click", "selector": "[aria-label*='detail' i], [title*='detail' i], button:has(svg)", "optional": true }, { "type": "wait", "ms": 2500 }] },
    { "route": "/confirm-orders", "filename": "order-pdf-download.png", "module": "documents", "fullPage": false, "actions": [{ "type": "downloadPdf", "menuSelector": "table tbody tr:first-child button:has(svg), [aria-label*='more' i]", "menuItemText": "PDF", "saveAs": "pdfs/order-sample.pdf" }] },
    { "route": "/fabrication-installation", "filename": "fabrication-installation.png", "module": "execution", "fullPage": false },
    { "route": "/installation/manager-approval", "filename": "installation-approval-drawer.png", "module": "execution", "fullPage": false, "actions": [{ "type": "click", "selector": "table tbody tr:first-child a, table tbody tr:first-child button", "optional": true }, { "type": "wait", "ms": 3000 }] },
    { "route": "/delivery-execution", "filename": "delivery-execution-drawer.png", "module": "execution", "fullPage": false, "actions": [{ "type": "click", "selector": "[class*='kanban'] [class*='card']:first-child, [data-rbd-draggable-id]:first-child", "optional": true }, { "type": "wait", "ms": 2500 }] },
    { "route": "/delivery-challans/new", "filename": "delivery-challan-form.png", "module": "execution", "fullPage": false },
    { "route": "/payment-outstanding", "filename": "payment-outstanding.png", "module": "payments", "fullPage": false },
    { "route": "/payment-outstanding", "filename": "payment-followup-dialog.png", "module": "payments", "fullPage": false, "actions": [{ "type": "click", "selector": "button:has-text('Follow'), [aria-label*='follow' i]", "optional": true }, { "type": "wait", "ms": 2000 }] },
    { "route": "/payment-audit", "filename": "payment-audit-approve.png", "module": "payments", "fullPage": false, "actions": [{ "type": "click", "selector": "button:has-text('Approve')", "optional": true }, { "type": "wait", "ms": 2000 }] },
    { "route": "/purchase-orders/add", "filename": "purchase-order-form.png", "module": "procurement", "fullPage": false },
    { "route": "/po-inwards/add", "filename": "po-inward-form.png", "module": "procurement", "fullPage": false },
    { "route": "/stocks", "filename": "stocks.png", "module": "procurement", "fullPage": false },
    { "route": "/b2b-sales-quotes/add", "filename": "b2b-quote-form.png", "module": "b2b", "fullPage": false },
    { "route": "/b2b-sales-orders/view?id={{b2bSalesOrderId}}", "filename": "b2b-order-detail.png", "module": "b2b", "fullPage": false, "requiresId": "b2bSalesOrderId" },
    { "route": "/b2b-invoices", "filename": "b2b-invoice-drawer.png", "module": "b2b", "fullPage": false, "actions": [{ "type": "click", "selector": "table tbody tr:first-child", "optional": true }, { "type": "wait", "ms": 2500 }] },
    { "route": "/commission-settlements/pending", "filename": "commission-review-drawer.png", "module": "commission", "fullPage": false, "actions": [{ "type": "click", "selector": "table tbody tr:first-child", "optional": true }, { "type": "wait", "ms": 2500 }] },
    { "route": "/service/dashboard", "filename": "service-dashboard.png", "module": "service", "fullPage": false },
    { "route": "/service/tickets/{{serviceTicketId}}", "filename": "service-ticket-detail.png", "module": "service", "fullPage": false, "requiresId": "serviceTicketId" },
    { "route": "/reports/payments", "filename": "reports-payments.png", "module": "reports", "fullPage": false },
    { "route": "/company-profile", "filename": "company-profile.png", "module": "settings", "fullPage": false }
  ]
}
